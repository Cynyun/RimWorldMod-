<ui:FluentWindow x:Class="RimWorldModManager.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:RimWorldModManager"
                 xmlns:views="clr-namespace:RimWorldModManager.Views"
                 mc:Ignorable="d"
                 Title="RimWorld Mod 管理器" Height="600" Width="1000"
                 WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="RimWorld Mod 管理器" />

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBox Grid.Column="0" 
                                    x:Name="WorkshopIdTextBox" 
                                    PlaceholderText="输入 Workshop ID"
                                    Margin="0,0,8,0" />

                        <ui:Button Grid.Column="1" 
                                   x:Name="DownloadButton" 
                                   Content="下载 Mod"
                                   Click="DownloadButton_Click" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBox Grid.Column="0" 
                                    x:Name="SearchTextBox"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="搜索 Mod..."
                                    Margin="0,0,8,0" />

                        <ui:Button Grid.Column="1" 
                                   x:Name="UpdateButton" 
                                   Content="更新选中"
                                   Click="UpdateButton_Click"
                                   Margin="0,0,8,0" />

                        <ui:Button Grid.Column="2" 
                                   x:Name="UpdateAllButton" 
                                   Content="更新全部"
                                   Click="UpdateAllButton_Click"
                                   Margin="0,0,8,0" />

                        <ui:Button Grid.Column="3" 
                                   x:Name="RefreshButton" 
                                   Content="刷新"
                                   Click="RefreshButton_Click"
                                   Margin="0,0,8,0" />

                        <ui:Button Grid.Column="4" 
                                   x:Name="SettingsButton" 
                                   Content="设置" 
                                   Click="SettingsButton_Click" />
                    </Grid>

                    <ScrollViewer Grid.Row="2" Margin="12" VerticalScrollBarVisibility="Auto">
                        <ui:DataGrid x:Name="ModsDataGrid"
                                     ItemsSource="{Binding Mods}"
                                     SelectedItem="{Binding SelectedMod}"
                                     AutoGenerateColumns="False"
                                     CanUserAddRows="False"
                                     CanUserDeleteRows="False"
                                     SelectionChanged="ModsDataGrid_SelectionChanged"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Stretch">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Workshop ID" 
                                                       Binding="{Binding WorkshopId}" 
                                                       Width="120" />
                                <DataGridTextColumn Header="Mod 名称" 
                                                       Binding="{Binding Name}" 
                                                       Width="*" />
                                <DataGridTextColumn Header="最后更新" 
                                                       Binding="{Binding LastUpdated, StringFormat='yyyy-MM-dd'}" 
                                                       Width="130" />
                            </DataGrid.Columns>
                        </ui:DataGrid>
                    </ScrollViewer>
                </Grid>
            </ui:Card>

            <ui:Card Grid.Column="1" Margin="16,0,0,0" Height="Auto">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto" Height="Auto">
                    <views:ModDetailPage 
                        x:Name="ModDetailPage" 
                        BackRequested="ModDetailPage_BackRequested" 
                        Height="Auto" />
                </ScrollViewer>
            </ui:Card>
        </Grid>

        <TextBlock Grid.Row="2" 
                   Text="{Binding StatusMessage}" 
                   Margin="16,8,0,8" 
                   FontSize="12" />
    </Grid>
</ui:FluentWindow>
