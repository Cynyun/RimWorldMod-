<ui:FluentWindow x:Class="RimWorldModManager.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2004"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:RimWorldModManager"
                 xmlns:views="clr-namespace:RimWorldModManager.Views"
                  mc:Ignorable="d"
                 Title="RimWorld Mod 管理器" Height="700" Width="1115"
                 WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="RimWorld Mod 管理器" />

        <DockPanel Grid.Row="1" Margin="8">
            <Button x:Name="ViewModeDropDown"
                    Content="{Binding CurrentViewModeText}"
                    Margin="0,0,4,0" 
                    Padding="12,6"
                    Width="120"
                    Click="ViewModeDropDown_Click">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="游戏 Mods" Click="LocalModsButton_Click" />
                        <MenuItem Header="Workshop" Click="WorkshopModsButton_Click" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
            <Separator Width="1" Background="Gray" Margin="4,0" />
            
            <ui:TextBox x:Name="WorkshopIdTextBox" 
                        PlaceholderText="输入 Workshop ID"
                        Width="150"
                        Margin="0,0,4,0" />
            <ui:Button x:Name="DownloadButton" 
                       Content="下载 Mod"
                       Click="DownloadButton_Click" 
                       Margin="0,0,4,0" />
            <ui:Button x:Name="BatchDownloadButton" 
                       Content="批量下载"
                       Click="BatchDownloadButton_Click" 
                       Margin="0,0,4,0" />
            <Separator Width="1" Background="Gray" Margin="4,0" />
            
            <ui:TextBox x:Name="SearchTextBox"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="搜索 Mod..."
                     Width="200"
                     Margin="4,0,4,0"/>
            <Separator Width="1" Background="Gray" Margin="4,0" />
            <TextBlock Text="排序:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="Gray" />
            <ComboBox x:Name="SortComboBox" Width="120" Margin="0,0,4,0" SelectionChanged="SortComboBox_SelectionChanged">
                <ComboBoxItem Content="名称" IsSelected="True" />
                <ComboBoxItem Content="修改时间" />
                <ComboBoxItem Content="Workshop ID" />
            </ComboBox>
            <ui:Button x:Name="SortDirectionButton" Content="{Binding SortDirectionText}" Click="SortDirectionButton_Click" Width="40" Margin="0,0,4,0" ToolTip="切换升序/降序" />
            <ui:Button Content="刷新" Click="RefreshButton_Click" Margin="0,0,4,0" />
            <ui:Button Content="设置" Click="SettingsButton_Click" />
        </DockPanel>

        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0" VerticalAlignment="Center">
                        <ui:Button Content="全选" Click="SelectAllButton_Click" 
                                   Visibility="{Binding IsWorkshopModsView, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                   Margin="0,0,4,0" />
                        <ui:Button Content="取消全选" Click="DeselectAllButton_Click" 
                                   Visibility="{Binding IsWorkshopModsView, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                   Margin="0,0,4,0" />
                        <ui:Button Content="导入选中到游戏" 
                                   Click="ImportButton_Click" 
                                   Visibility="{Binding IsWorkshopModsView, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                   Margin="0,0,4,0" />
                        <ui:Button Content="更新选中" 
                                   Click="UpdateSelectedButton_Click" 
                                   Visibility="{Binding IsWorkshopModsView, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                   Margin="0,0,4,0" />
                        <Separator Width="1" Background="Gray" Margin="4,0" Visibility="{Binding IsWorkshopModsView, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ui:Button x:Name="OpenFolderButton" Content="打开文件夹" Click="OpenFolderButton_Click" />
                        <ui:Button x:Name="OpenWorkshopButton" Content="打开 Workshop" 
                                   Click="OpenWorkshopButton_Click" 
                                   Visibility="{Binding SelectedModDetail.HasWorkshopId, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                   Margin="4,0,0,0" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" Margin="8" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ListBox x:Name="LocalModsList"
                                     ItemsSource="{Binding LocalMods}"
                                     Visibility="{Binding IsLocalModsView, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     Margin="0,0,0,4"
                                     SelectionMode="Single"
                                     SelectionChanged="LocalModsList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="320" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{Binding WorkshopSourceInfo}" Foreground="Gray" FontSize="12" Margin="4,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding LastModified, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Foreground="Gray" FontSize="12" Margin="4,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ListBox x:Name="WorkshopModsList"
                                     ItemsSource="{Binding WorkshopMods}"
                                     Visibility="{Binding IsWorkshopModsView, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     SelectionMode="Single"
                                     SelectionChanged="WorkshopModsList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="320" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Selected}" Margin="0,0,4,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{Binding WorkshopId, StringFormat='ID: {0}'}" Foreground="Gray" FontSize="12" Margin="4,0" />
                                            <TextBlock Grid.Column="3" Text="已导入" 
                                                       Foreground="Green" FontSize="12"
                                                       Visibility="{Binding IsImported, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="4,0" />
                                            <TextBlock Grid.Column="4" Text="{Binding LastModified, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Foreground="Gray" FontSize="12" Margin="4,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </ui:Card>

            <ui:Card Grid.Column="1" Margin="8,0,0,0">
                <ScrollViewer Margin="8" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Mod 详情" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
                        
                        <Border Width="240" BorderThickness="1" BorderBrush="Gray" Background="#2a2a2a" CornerRadius="4" Margin="0,0,0,12" ClipToBounds="True">
                            <Grid>
                                <Image Source="{Binding SelectedModDetail.PreviewImagePath}" 
                                       Stretch="Uniform" 
                                       Visibility="{Binding SelectedModDetail.HasPreviewImage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock Text="暂无预览图片" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           Foreground="Gray"
                                           Visibility="{Binding SelectedModDetail.HasPreviewImage, Converter={StaticResource BooleanToInverseVisibilityConverter}}" />
                            </Grid>
                        </Border>
                        
                        <TextBlock Text="名称:" Foreground="Gray" Margin="0,0,0,4" />
                        <TextBlock x:Name="DetailName" Text="{Binding SelectedModDetail.Name}" FontWeight="Bold" Margin="0,0,0,4" />
                        
                        <TextBlock Text="作者:" Foreground="Gray" Margin="0,0,0,4" />
                        <TextBlock x:Name="DetailAuthor" Text="{Binding SelectedModDetail.Author}" Margin="0,0,0,4" />
                        
                        <TextBlock Text="版本:" Foreground="Gray" Margin="0,0,0,4" />
                        <TextBlock x:Name="DetailVersion" Text="{Binding SelectedModDetail.Version}" Margin="0,0,0,4" />
                        
                        <TextBlock Text="Workshop ID:" Foreground="Gray" Margin="0,0,0,4" />
                        <TextBlock x:Name="DetailWorkshopId" Text="{Binding SelectedModDetail.WorkshopId}" Margin="0,0,0,4" />
                        
                        <TextBlock Text="描述:" Foreground="Gray" Margin="0,0,0,4" />
                        <TextBlock x:Name="DetailDescription" Text="{Binding SelectedModDetail.Description}" TextWrapping="Wrap" Margin="0,0,0,4" />
                        
                        <TextBlock Text="标签:" Foreground="Gray" Margin="0,0,0,4" />
                        <TextBlock x:Name="DetailTags" Text="{Binding SelectedModDetail.TagsString}" Margin="0,0,0,12" />
                        

                    </StackPanel>
                </ScrollViewer>
            </ui:Card>
        </Grid>

        <StackPanel Grid.Row="3" Margin="16,0,4,16">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Margin="0,0,2,0" />
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding ProgressText}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ProgressBar Grid.Column="1" x:Name="TotalProgressBar" 
                             Value="{Binding CurrentProgress}" 
                             Maximum="{Binding TotalProgress}"
                             Height="4"
                             Margin="0,0,0,0" />
            </Grid>
        </StackPanel>
    </Grid>
</ui:FluentWindow>