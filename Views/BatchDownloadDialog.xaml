<ui:FluentWindow x:Class="RimWorldModManager.Views.BatchDownloadDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="批量下载 Mod" Height="700" Width="1000"
                 WindowStartupLocation="CenterOwner"
                 MouseDown="FluentWindow_MouseDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="批量下载 Mod" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="输入 Workshop ID（每行一个）" Margin="0,0,0,8" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <ui:TextBox x:Name="WorkshopIdsTextBox"
                                AcceptsReturn="True"
                                PlaceholderText="输入 Workshop ID，每行一个&#10;例如：&#10;123456789&#10;987654321"
                                VerticalScrollBarVisibility="Auto" />
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <ui:Button Content="添加到列表" 
                               Click="AddToListButton_Click" 
                               Margin="0,0,8,0" />
                    <ui:Button Content="清空列表" 
                               Click="ClearListButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="已添加的 Workshop ID" Margin="0,0,0,8" />

                <ListBox Grid.Row="1" x:Name="WorkshopIdsList" Margin="0,0,0,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" 
                                           Content="删除" 
                                           Width="60" 
                                           Height="28" 
                                           Margin="8,0,0,0"
                                           Click="DeleteItemButton_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="1" 
                       Content="下载" 
                       Click="DownloadButton_Click"
                       Margin="0,0,8,0" />
            <ui:Button Grid.Column="2" 
                       Content="取消" 
                       Click="CancelButton_Click" />
        </Grid>
    </Grid>
</ui:FluentWindow>