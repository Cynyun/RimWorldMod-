<ui:FluentWindow x:Class="RimWorldModManager.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="设置" Height="420" Width="550"
                 WindowStartupLocation="CenterOwner"
                 MouseDown="FluentWindow_MouseDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Text="SteamCMD 路径" Margin="0,0,0,8" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" 
                            Text="{Binding SteamCmdPath}" 
                            PlaceholderText="请输入 steamcmd.exe 的路径"
                            Margin="0,0,8,0" />
                <ui:Button Grid.Column="1" 
                           Content="浏览..." 
                           Click="BrowseSteamCmd_Click" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock Text="Mod 下载路径" Margin="0,0,0,8" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" 
                            Text="{Binding ModDownloadPath}" 
                            PlaceholderText="请输入 Mod 下载后的存储路径"
                            Margin="0,0,8,0" />
                <ui:Button Grid.Column="1" 
                           Content="浏览..." 
                           Click="BrowseModPath_Click" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Text="Steam 账号" Margin="0,0,0,8" />
            <ui:TextBox 
                x:Name="SteamAccountTextBox"
                Text="{Binding SteamAccount}" 
                PlaceholderText="输入 Steam 账号"
                TextChanged="SteamAccountTextBox_TextChanged" />
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,16,0,0">
            <TextBlock Text="Steam 密码" Margin="0,0,0,8" />
            <ui:PasswordBox 
                x:Name="SteamPasswordBox"
                PlaceholderText="输入 Steam 密码"
                PasswordChanged="SteamPasswordBox_PasswordChanged" />
        </StackPanel>

        <Grid Grid.Row="6" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="1" 
                       Content="确定" 
                       Click="SaveButton_Click"
                       Margin="0,0,8,0" />
            <ui:Button Grid.Column="2" 
                       Content="取消" 
                       Click="CancelButton_Click" />
        </Grid>
    </Grid>
</ui:FluentWindow>
